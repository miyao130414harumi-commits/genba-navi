    const r = await api('importTsv', { tsv });
    if (r.ok){
      flash('import-msg', `${r.added}問追加したよ!` + (r.skipped ? `(${r.skipped}行スキップ)` : ''), true);
      document.getElementById('import-tsv').value = '';
      const rt = await api('getTasks');
      if (rt.ok){ ALL_TASKS = rt.tasks; setupStart(); showScreen('screen-admin'); }
    } else {
      flash('import-msg', r.error || 'インポートに失敗しました', false);
    }
  }catch(e){
    flash('import-msg', '通信エラーが発生しました', false);
  }
  btn.disabled = false;
});

// ---------- 管理者:削除 ----------
document.getElementById('btn-delete').addEventListener('click', async () => {
  const id = document.getElementById('del-id').value.trim();
  if (!id){ flash('del-msg', '課題IDを入力してね', false); return; }
  if (!confirm(`${id} を削除する?この操作は戻せないよ`)) return;
  try{
    const r = await api('deleteTask', { id });
    if (r.ok){
      flash('del-msg', `${id} を削除したよ`, true);
      document.getElementById('del-id').value = '';
      const rt = await api('getTasks');
      if (rt.ok){ ALL_TASKS = rt.tasks; setupStart(); showScreen('screen-admin'); }
    } else {
      flash('del-msg', r.error || '削除に失敗しました', false);
    }
  }catch(e){
    flash('del-msg', '通信エラーが発生しました', false);
  }
});

// ---------- 初期化 ----------
(function init(){
  const saved = loadSessionSaved();
  if (saved && saved.name && saved.pass){
    doLogin(saved.name, saved.pass, true);
  } else {
    showScreen('screen-login');
  }
})();
</script>
