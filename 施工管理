// ---------- データ読み込み ----------
async function loadData(){
  showLoading('課題を読み込み中…');
  const [rt, rf] = await Promise.all([api('getTasks'), api('getFavorites')]);
  if (!rt.ok){ showScreen('screen-login'); flash('login-msg', rt.error || '読み込みに失敗しました', false); return; }
  ALL_TASKS = rt.tasks;
  favoriteIds = new Set(rf.ok ? rf.ids : []);
  setupStart();
  showScreen('screen-start');
}

// ---------- スタート画面 ----------
function setupStart(){
  const cats = [...new Set(ALL_TASKS.map(q => q.category))];
  const wrap = document.getElementById('category-chips');
  wrap.innerHTML = '';
  wrap.appendChild(makeCatChip('すべて', 'all', selectedCategory === 'all'));
  cats.forEach(c => wrap.appendChild(makeCatChip(c, c, selectedCategory === c)));
  if (![...cats, 'all'].includes(selectedCategory)) selectedCategory = 'all';

  const dl = document.getElementById('category-list');
  dl.innerHTML = '';
  cats.forEach(c => {
    const o = document.createElement('option');
    o.value = c;
    dl.appendChild(o);
  });

  const nChoice = ALL_TASKS.filter(t => t.type === '選択').length;
  const nWritten = ALL_TASKS.length - nChoice;
  document.getElementById('data-info').textContent =
    `課題:${ALL_TASKS.length}問(選択${nChoice}・記述${nWritten})/ お気に入り:${favoriteIds.size}`;
}
function makeCatChip(label, value, selected){
  const b = document.createElement('button');
  b.className = 'chip' + (selected ? ' selected' : '');
  b.textContent = label;
  b.addEventListener('click', () => {
    document.querySelectorAll('#category-chips .chip').forEach(x => x.classList.remove('selected'));
    b.classList.add('selected');
    selectedCategory = value;
  });
  return b;
}
document.getElementById('count-chips').addEventListener('click', e => {
  const b = e.target.closest('.chip');
  if (!b) return;
  document.querySelectorAll('#count-chips .chip').forEach(x => x.classList.remove('selected'));
  b.classList.add('selected');
  selectedCount = b.dataset.count === 'all' ? 'all' : parseInt(b.dataset.count, 10);
});
document.getElementById('scope-chips').addEventListener('click', e => {
  const b = e.target.closest('.chip');
  if (!b) return;
  document.querySelectorAll('#scope-chips .chip').forEach(x => x.classList.remove('selected'));
  b.classList.add('selected');
  selectedScope = b.dataset.scope;
});
document.getElementById('btn-start').addEventListener('click', () => {
  let pool = ALL_TASKS;
  if (selectedScope === 'fav') pool = pool.filter(q => favoriteIds.has(q.id));
  if (selectedScope === 'choice') pool = pool.filter(q => q.type === '選択');
  if (selectedScope === 'written') pool = pool.filter(q => q.type === '記述');
  if (selectedCategory !== 'all') pool = pool.filter(q => q.category === selectedCategory);
  if (pool.length === 0){
    alert(selectedScope === 'fav'
      ? 'お気に入りに課題がまだないよ。課題中に☆を押して登録してね'
      : 'この条件に合う課題がありません');
    return;
  }
  taskSet = shuffle(pool);
  if (selectedCount !== 'all') taskSet = taskSet.slice(0, selectedCount);
  currentIndex = 0; correctCount = 0; choiceTotal = 0; writtenCount = 0; wrongTasks = [];
  showScreen('screen-task');
  renderTask();
});

// ---------- 課題表示 ----------
function renderTask(){
  answered = false;
  const q = taskSet[currentIndex];
  document.getElementById('q-counter').textContent = `${currentIndex + 1} / ${taskSet.length}`;
  document.getElementById('q-score').textContent = `選択正解 ${correctCount}`;
  document.getElementById('progress-fill').style.width = `${(currentIndex / taskSet.length) * 100}%`;
  document.getElementById('q-category').textContent = q.category;
  document.getElementById('q-text').textContent = q.text;

  const typeBadge = document.getElementById('q-type');
  typeBadge.textContent = q.type;
  typeBadge.className = 'q-type ' + (q.type === '選択' ? 'choice' : 'written');
  renderFavButton(q);

  const choicesWrap = document.getElementById('choices');
  const writtenArea = document.getElementById('written-area');
  choicesWrap.innerHTML = '';

  if (q.type === '選択'){
    writtenArea.classList.remove('show');
    q.choices.forEach((c, i) => {
      const b = document.createElement('button');
      b.className = 'choice';
      b.innerHTML = `<span class="num">${i + 1}</span><span>${escapeHtml(c)}</span>`;
      b.addEventListener('click', () => answerChoice(i, b));
      choicesWrap.appendChild(b);
    });
  } else {
    writtenArea.classList.add('show');
    document.getElementById('written-input').value = '';
    document.getElementById('btn-submit-written').disabled = false;
  }

  document.getElementById('judge').className = 'judge';
  document.getElementById('btn-next').style.display = 'none';
}
function renderFavButton(q){
  const btn = document.getElementById('btn-fav');
  const on = favoriteIds.has(q.id);
  btn.textContent = on ? '★ お気に入り済' : '☆ お気に入り';
  btn.className = 'btn-fav' + (on ? ' on' : '');
}
document.getElementById('btn-fav').addEventListener('click', async () => {
  const q = taskSet[currentIndex];
  if (favoriteIds.has(q.id)) favoriteIds.delete(q.id); else favoriteIds.add(q.id);
  renderFavButton(q);
  try{
    const r = await api('toggleFavorite', { id: q.id });
    if (r.ok){
      if (r.favorited) favoriteIds.add(q.id); else favoriteIds.delete(q.id);
    } else {
      if (favoriteIds.has(q.id)) favoriteIds.delete(q.id); else favoriteIds.add(q.id);
    }
  }catch(e){
    if (favoriteIds.has(q.id)) favoriteIds.delete(q.id); else favoriteIds.add(q.id);
  }
  renderFavButton(q);
});

// ---------- 選択問題の解答 ----------
function answerChoice(i, btn){
  if (answered) return;
  answered = true;
  const q = taskSet[currentIndex];
  choiceTotal++;
  const buttons = document.querySelectorAll('#choices .choice');
  buttons.forEach(b => b.disabled = true);
  const correctIdx = q.answer - 1;
  buttons[correctIdx].classList.add('correct');

  const judge = document.getElementById('judge');
  const mark = document.getElementById('judge-mark');

  if (i === correctIdx){
    correctCount++;
    judge.classList.add('ok', 'show');
    mark.textContent = '○ 正解!';
  } else {
    btn.classList.add('wrong');
    wrongTasks.push(q);
    judge.classList.add('ng', 'show');
    mark.textContent = `× 不正解(正解は ${q.answer})`;
  }
  document.getElementById('judge-text').textContent = q.explanation || '';
  document.getElementById('q-score').textContent = `選択正解 ${correctCount}`;

  // 記録として送信(失敗しても続行)
  api('submitAnswer', { taskId: q.id, value: i + 1 }).catch(() => {});

  showNextButton();
}

// ---------- 記述課題の提出 ----------
document.getElementById('btn-submit-written').addEventListener('click', async () => {
  if (answered) return;
  const q = taskSet[currentIndex];
  const value = document.getElementById('written-input').value.trim();
  if (!value){ alert('回答を入力してね'); return; }
  const btn = document.getElementById('btn-submit-written');
  btn.disabled = true;
  try{
    const r = await api('submitAnswer', { taskId: q.id, value });
    if (!r.ok){
      alert(r.error || '提出に失敗しました');
      btn.disabled = false;
      return;
    }
    answered = true;
    writtenCount++;
    const judge = document.getElementById('judge');
    judge.classList.add('info', 'show');
    document.getElementById('judge-mark').textContent = '📝 提出したよ!管理者が確認するね';
    document.getElementById('judge-text').textContent =
      q.explanation ? '【模範解答・ポイント】\n' + q.explanation : '';
    showNextButton();
  }catch(e){
    alert('通信エラーが発生しました');
    btn.disabled = false;
  }
});

function showNextButton(){
  const nextBtn = document.getElementById('btn-next');
  nextBtn.textContent = currentIndex + 1 < taskSet.length ? '次へ' : '結果を見る';
  nextBtn.style.display = 'block';
}
document.getElementById('btn-next').addEventListener('click', () => {
  if (currentIndex + 1 < taskSet.length){
    currentIndex++;
    renderTask();
  } else {
    showResult();
  }
});

// ---------- 結果 ----------
function showResult(){
  showScreen('screen-result');
  document.getElementById('result-score').textContent = correctCount;
  document.getElementById('result-total').textContent = choiceTotal;

  let msg;
  if (choiceTotal === 0) msg = '記述課題おつかれさま!';
  else {
    const rate = correctCount / choiceTotal;
    if (rate === 1)       msg = '選択問題オール正解!安全大臣!🏆';
    else if (rate >= 0.8) msg = '合格ライン突破!この調子!';
    else if (rate >= 0.6) msg = 'あと一歩!間違いを復習しよう';
    else                  msg = '焦らずコツコツ。復習が近道!';
  }
  document.getElementById('result-msg').textContent = msg;
  document.getElementById('result-written').textContent =
    writtenCount > 0 ? `記述課題 ${writtenCount}件を提出済み(管理者確認待ち)` : '';

  const retryBtn = document.getElementById('btn-retry-wrong');
  const wrongCard = document.getElementById('wrong-card');
  const list = document.getElementById('wrong-list');
  list.innerHTML = '';

  if (wrongTasks.length > 0){
    retryBtn.style.display = 'block';
    retryBtn.textContent = `間違えた${wrongTasks.length}問だけ復習`;
    wrongCard.style.display = 'block';
    wrongTasks.forEach(q => {
      const d = document.createElement('div');
      d.className = 'wrong-item';
      d.innerHTML =
        `<div class="wq">【${escapeHtml(q.category)}】${escapeHtml(q.text)}</div>` +
        `<div class="wa">正解:${q.answer}. ${escapeHtml(q.choices[q.answer - 1])}</div>` +
        (q.explanation ? `<div>${escapeHtml(q.explanation)}</div>` : '');
      list.appendChild(d);
    });
  } else {
    retryBtn.style.display = 'none';
    wrongCard.style.display = 'none';
  }
}
document.getElementById('btn-retry-wrong').addEventListener('click', () => {
  taskSet = shuffle(wrongTasks.slice());
  currentIndex = 0; correctCount = 0; choiceTotal = 0; writtenCount = 0; wrongTasks = [];
  showScreen('screen-task');
  renderTask();
});
