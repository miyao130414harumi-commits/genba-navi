document.getElementById('btn-generate').addEventListener('click', async () => {
  const file = document.getElementById('pdf-file').files[0];
  if (!file){ flash('pdf-msg', 'PDFファイルを選んでね', false); return; }
  if (file.size > 20 * 1024 * 1024){ flash('pdf-msg', 'PDFが大きすぎるよ(20MBまで推奨)', false); return; }

  const btn = document.getElementById('btn-generate');
  btn.disabled = true;
  btn.textContent = 'AIが作成中…(1〜2分かかることも)';
  try{
    const base64 = await new Promise((res, rej) => {
      const r = new FileReader();
      r.onload = () => res(r.result.split(',')[1]);
      r.onerror = () => rej(new Error('読み込み失敗'));
      r.readAsDataURL(file);
    });
    const r = await api('generateFromPdf', {
      mode: pdfMode,
      count: parseInt(document.getElementById('pdf-count').value, 10) || 10,
      category: document.getElementById('pdf-category').value.trim(),
      pdfBase64: base64
    });
    if (!r.ok){
      flash('pdf-msg', r.error || '生成に失敗しました', false);
    } else {
      previewItems = r.items;
      renderPreview();
    }
  }catch(e){
    flash('pdf-msg', '通信エラーが発生しました', false);
  }
  btn.disabled = false;
  btn.textContent = 'AIで課題を作る';
});
function renderPreview(){
  const area = document.getElementById('preview-area');
  const list = document.getElementById('preview-list');
  const nChoice = previewItems.filter(t => t.type === '選択').length;
  document.getElementById('preview-info').textContent =
    `${previewItems.length}問できたよ(選択${nChoice}・記述${previewItems.length - nChoice})。内容を確認してね:`;
  list.innerHTML = '';
  previewItems.forEach((t, idx) => {
    const d = document.createElement('div');
    d.className = 'prev-item';
    let html = `<div class="pt">${idx + 1}.【${escapeHtml(t.type)}/${escapeHtml(t.category || '未分類')}】${escapeHtml(t.text)}</div>`;
    if (t.type === '選択' && t.choices){
      html += t.choices.map((c, i) =>
        `<div>${i + 1 === Number(t.answer) ? '◎' : '・'}${i + 1}. ${escapeHtml(c)}</div>`).join('');
    }
    if (t.explanation) html += `<div style="color:#666">→ ${escapeHtml(t.explanation)}</div>`;
    d.innerHTML = html;
    list.appendChild(d);
  });
  area.style.display = 'block';
  area.scrollIntoView({ behavior: 'smooth' });
}
